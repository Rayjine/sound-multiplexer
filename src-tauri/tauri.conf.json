{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sound Multiplexer",
  "version": "1.0.0",
  "identifier": "io.github.rayjine.SoundMultiplexer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sound Multiplexer",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 450
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "nsis"],
    "category": "Utility",
    "shortDescription": "Play audio through several output devices at once",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "section": "sound"
      }
    }
  }
}
